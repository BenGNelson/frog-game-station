# Frog Game Station — configuration. Copy this file to .env and fill it in.
# .env holds REAL values and is gitignored — never commit it. Compose reads it.
# Every value here has a sensible default, so a clean clone boots as-is.

# --- Ports ---
# Host port the app is served on (open http://localhost:8585 by default).
FRONTEND_PORT=8585
# Optional direct backend API port (for curl/debugging; the frontend proxies
# /api over the internal network regardless).
API_PORT=8586
# Host port for the hot-reload dev server (compose --profile dev).
DEV_PORT=5174

# --- Your games ---
# Host directory containing your ROMs. Mounted read-only into the backend.
# Point this at your collection; defaults to the repo's empty ./roms so a fresh
# clone still starts (the app shows its "no ROMs configured" first-run state).
ROMS_DIR=./roms

# --- IGDB metadata (optional but recommended) ---
# Credentials for rich game data (cover art, screenshots, summaries, genres,
# ratings). Create an application at https://dev.twitch.tv/console/apps to get a
# Client ID + Secret (IGDB uses Twitch OAuth). Leave blank to run without it —
# the app falls back to libretro box art and shows a "not configured" note.
IGDB_CLIENT_ID=
IGDB_CLIENT_SECRET=
# How often the background matcher rescans the library for new/changed ROMs
# (seconds). Default is once a day.
IGDB_SYNC_ENABLED=true
IGDB_SYNC_INTERVAL=86400

# --- In-game wiki reader (optional) ---
# The in-player wiki browser: read a game's wiki (Bulbapedia, Fandom, Wikipedia)
# over the paused game, controller- and touch-navigable. Links come from IGDB
# automatically; set one by hand from the reader for anything unmatched (e.g. a
# ROM hack). Set false to hide the feature.
WIKI_ENABLED=true
# Extra image hosts the wiki image-proxy may fetch from, comma-separated — on top
# of the article's own domain and the built-in MediaWiki CDNs. Usually leave blank.
WIKI_PROXY_ALLOW_HOSTS=
# How long a fetched article is cached before a re-fetch (seconds). Default one day.
WIKI_CACHE_TTL=86400
